<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Streamflux — Market Faster. Close More. Powered by AI.</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
--navy: #111827;
--navy-mid: #122840;
--blue: #1A6FA8;
--aqua: #2AB8D4;
--aqua-light: #5DCFE0;
--white: #FFFFFF;
--off-white: #F4F8FB;
--text: #0D1B2A;
--muted: #5A7A96;
--border: rgba(42, 184, 212, 0.2);
}

html { scroll-behavior: smooth; }

body {
font-family: 'DM Sans', sans-serif;
background: var(--white);
color: var(--text);
overflow-x: hidden;
}

.video-end-screen {
position: absolute;
top: 0; left: 0; right: 0; bottom: 0;
background: rgba(10, 20, 35, 0.92);
display: flex;
align-items: center;
justify-content: center;
border-radius: 10px;
opacity: 0;
pointer-events: none;
transition: opacity 0.5s ease;
}
.video-end-screen.visible {
opacity: 1;
pointer-events: all;
}
.video-end-content { text-align: center; }
.video-end-label {
font-family: 'DM Serif Display', serif;
font-size: 22px;
font-style: italic;
color: rgba(255,255,255,0.8);
margin-bottom: 20px;
}
.video-end-btn {
background: var(--aqua);
color: var(--navy);
border: none;
border-radius: 6px;
padding: 16px 36px;
font-size: 15px;
font-weight: 700;
font-family: 'DM Sans', sans-serif;
cursor: pointer;
letter-spacing: 0.5px;
transition: all 0.2s;
box-shadow: 0 0 40px rgba(42,184,212,0.4);
}
.video-end-btn:hover {
background: var(--aqua-light);
transform: translateY(-2px);
}

/* ── HERO VIDEO ── */
.hero-video-wrap {
width: 100%;
max-width: 680px;
margin-bottom: 40px;
border-radius: 10px;
overflow: hidden;
border: 1px solid rgba(42,184,212,0.3);
box-shadow: 0 0 60px rgba(42,184,212,0.15);
}
.hero-video-inner {
position: relative;
width: 100%;
padding-top: 56.25%;
}
.hero-video-inner iframe,
.hero-video-inner video {
position: absolute;
top: 0; left: 0;
width: 100%; height: 100%;
border-radius: 10px;
}
.video-placeholder {
position: absolute;
top: 0; left: 0; right: 0; bottom: 0;
background: rgba(255,255,255,0.04);
border-radius: 10px;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 12px;
border: 2px dashed rgba(42,184,212,0.3);
}
.play-btn {
width: 64px;
height: 64px;
border-radius: 50%;
background: var(--aqua);
display: flex;
align-items: center;
justify-content: center;
font-size: 22px;
color: var(--navy);
padding-left: 4px;
}
.video-placeholder-text {
font-family: 'DM Serif Display', serif;
font-size: 18px;
color: rgba(255,255,255,0.7);
}
.video-placeholder-sub {
font-size: 12px;
color: rgba(255,255,255,0.3);
text-align: center;
max-width: 300px;
line-height: 1.6;
}

/* ── NAVIGATION ── */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 100;
padding: 20px 48px;
display: flex;
align-items: center;
justify-content: space-between;
background: rgba(255,255,255,0.92);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(42,184,212,0.15);
gap: 20px;
}

.nav-logo {
font-family: 'Bebas Neue', sans-serif;
font-size: 28px;
letter-spacing: 3px;
color: var(--navy);
text-decoration: none;
flex-shrink: 0;
}
.nav-logo span { color: var(--aqua); }

.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a {
font-size: 13px;
font-weight: 500;
letter-spacing: 0.5px;
color: var(--muted);
text-decoration: none;
transition: color 0.2s;
}
.nav-links a:hover { color: var(--navy); }

.nav-cta {
background: var(--aqua) !important;
color: var(--white) !important;
padding: 10px 24px !important;
border-radius: 4px !important;
font-weight: 500 !important;
letter-spacing: 0.5px !important;
transition: background 0.2s !important;
}
.nav-cta:hover { background: var(--blue) !important; }

/* ── HERO ── */
.hero {
min-height: 100vh;
background: var(--navy);
position: relative;
overflow: hidden;
display: flex;
align-items: center;
padding: 120px 48px 80px;
}

.hero::before {
content: '';
position: absolute;
inset: 0;
background:
radial-gradient(ellipse 80% 50% at 50% 120%, rgba(42,184,212,0.12) 0%, transparent 60%),
radial-gradient(ellipse 60% 40% at 80% 60%, rgba(26,111,168,0.15) 0%, transparent 50%),
radial-gradient(ellipse 40% 60% at 20% 40%, rgba(42,184,212,0.08) 0%, transparent 50%);
pointer-events: none;
}

.hero::after {
content: '';
position: absolute;
bottom: 0; left: 0; right: 0;
height: 3px;
background: linear-gradient(90deg, transparent, var(--aqua), var(--aqua-light), transparent);
animation: speedLine 3s ease-in-out infinite;
}
@keyframes speedLine {
0%, 100% { opacity: 0.4; transform: scaleX(0.7); }
50% { opacity: 1; transform: scaleX(1); }
}

.wake {
position: absolute;
bottom: 60px; left: 0; right: 0;
height: 200px;
pointer-events: none;
overflow: hidden;
}
.wake-line {
position: absolute;
bottom: 0;
width: 100%;
height: 1px;
background: linear-gradient(90deg, transparent 0%, rgba(42,184,212,0.3) 30%, rgba(93,207,224,0.5) 50%, rgba(42,184,212,0.3) 70%, transparent 100%);
animation: wakeMove 4s ease-in-out infinite;
}
.wake-line:nth-child(1) { bottom: 20px; animation-delay: 0s; opacity: 0.8; }
.wake-line:nth-child(2) { bottom: 45px; animation-delay: 0.4s; opacity: 0.5; }
.wake-line:nth-child(3) { bottom: 70px; animation-delay: 0.8s; opacity: 0.3; }
.wake-line:nth-child(4) { bottom: 100px; animation-delay: 1.2s; opacity: 0.15; }
.wake-line:nth-child(5) { bottom: 135px; animation-delay: 1.6s; opacity: 0.08; }
@keyframes wakeMove {
0%, 100% { transform: translateX(-2%) scaleY(1); }
50% { transform: translateX(2%) scaleY(1.5); }
}

.hero-content {
position: relative;
z-index: 2;
max-width: 800px;
}

.hero-eyebrow {
display: inline-flex;
align-items: center;
gap: 10px;
font-size: 11px;
font-weight: 500;
letter-spacing: 4px;
text-transform: uppercase;
color: var(--aqua);
margin-bottom: 28px;
}

.hero-title {
font-family: 'Bebas Neue', sans-serif;
font-size: clamp(64px, 9vw, 130px);
line-height: 0.92;
letter-spacing: 2px;
color: var(--white);
margin-bottom: 32px;
}
.hero-title .aqua { color: var(--aqua); }
.hero-title .line2 {
display: block;
-webkit-text-stroke: 1px rgba(255,255,255,0.4);
color: transparent;
}

.hero-sub {
font-size: 18px;
color: rgba(255,255,255,0.75);
margin-bottom: 36px;
font-style: italic;
font-family: 'DM Serif Display', serif;
letter-spacing: 0.3px;
line-height: 1.5;
}

.hero-ctas {
display: flex;
gap: 16px;
flex-wrap: wrap;
align-items: center;
}

.btn-primary {
display: inline-flex;
align-items: center;
gap: 10px;
background: var(--aqua);
color: var(--white);
font-size: 14px;
font-weight: 500;
letter-spacing: 0.5px;
padding: 16px 36px;
border-radius: 4px;
text-decoration: none;
transition: all 0.2s;
border: none;
cursor: pointer;
font-family: 'DM Sans', sans-serif;
}
.btn-primary:hover { background: var(--aqua-light); transform: translateY(-1px); }
.btn-primary .arrow { transition: transform 0.2s; }
.btn-primary:hover .arrow { transform: translateX(4px); }

.btn-secondary {
display: inline-flex;
align-items: center;
gap: 10px;
background: transparent;
color: rgba(255,255,255,0.7);
font-size: 14px;
font-weight: 400;
letter-spacing: 0.5px;
padding: 16px 28px;
border-radius: 4px;
text-decoration: none;
border: 1px solid rgba(255,255,255,0.2);
transition: all 0.2s;
font-family: 'DM Sans', sans-serif;
}
.btn-secondary:hover { border-color: var(--aqua); color: var(--aqua); }

.hero-stats {
display: flex;
gap: 48px;
margin-top: 64px;
padding-top: 40px;
border-top: 1px solid rgba(255,255,255,0.08);
flex-wrap: wrap;
}
.stat-num {
font-family: 'Bebas Neue', sans-serif;
font-size: 42px;
letter-spacing: 1px;
color: var(--aqua);
line-height: 1;
}
.stat-label {
font-size: 12px;
color: rgba(255,255,255,0.4);
letter-spacing: 1px;
text-transform: uppercase;
margin-top: 4px;
}

/* ── PROBLEM SECTION ── */
.problem {
padding: 100px 48px;
background: var(--off-white);
}
.section-inner { max-width: 1100px; margin: 0 auto; }

.section-eyebrow {
font-size: 11px;
font-weight: 500;
letter-spacing: 4px;
text-transform: uppercase;
color: var(--aqua);
margin-bottom: 20px;
display: flex;
align-items: center;
gap: 12px;
}
.section-eyebrow::after {
content: '';
flex: 1;
max-width: 60px;
height: 1px;
background: var(--aqua);
}

.section-title {
font-family: 'DM Serif Display', serif;
font-size: clamp(32px, 4vw, 52px);
line-height: 1.1;
color: var(--navy);
margin-bottom: 20px;
}
.section-title em { font-style: italic; color: var(--blue); }

.section-sub {
font-size: 17px;
color: var(--muted);
line-height: 1.7;
max-width: 600px;
margin-bottom: 60px;
}

.pain-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
gap: 24px;
}

.pain-card {
background: var(--white);
border: 1px solid rgba(0,0,0,0.07);
border-radius: 4px;
padding: 32px;
position: relative;
overflow: hidden;
transition: transform 0.2s, box-shadow 0.2s;
}
.pain-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(11,30,53,0.1); }
.pain-card::before {
content: '';
position: absolute;
top: 0; left: 0; right: 0;
height: 3px;
background: linear-gradient(90deg, var(--blue), var(--aqua));
}
.pain-icon { font-size: 28px; margin-bottom: 16px; display: block; }
.pain-title {
font-family: 'DM Serif Display', serif;
font-size: 20px;
color: var(--navy);
margin-bottom: 10px;
}
.pain-desc { font-size: 14px; color: var(--muted); line-height: 1.7; }

/* ── SOLUTION SECTION ── */
.solution { padding: 100px 48px; background: var(--white); }

.apps-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(440px, 1fr));
gap: 32px;
margin-top: 60px;
}

.app-card {
border-radius: 6px;
overflow: hidden;
border: 1px solid var(--border);
transition: transform 0.3s, box-shadow 0.3s;
}
.app-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(42,184,212,0.12); }

.app-card-header {
background: var(--navy);
padding: 36px 36px 28px;
position: relative;
overflow: hidden;
}
.app-card-header::after {
content: '';
position: absolute;
bottom: 0; left: 0; right: 0;
height: 2px;
background: linear-gradient(90deg, var(--blue), var(--aqua), var(--aqua-light));
}
.app-number {
font-family: 'Bebas Neue', sans-serif;
font-size: 72px;
color: rgba(42,184,212,0.15);
line-height: 1;
position: absolute;
top: 16px; right: 28px;
letter-spacing: 2px;
}
.app-tag { font-size: 10px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--aqua); margin-bottom: 12px; }
.app-name { font-family: 'DM Serif Display', serif; font-size: 26px; color: var(--white); margin-bottom: 8px; }
.app-desc { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.6; }

.app-card-body { padding: 32px 36px; background: var(--off-white); }
.app-features { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.app-features li { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; color: var(--text); line-height: 1.5; }
.app-features li::before { content: '→'; color: var(--aqua); font-weight: 600; flex-shrink: 0; margin-top: 1px; }

/* ── PRICING ── */
.pricing {
padding: 100px 48px;
background: var(--navy);
position: relative;
overflow: hidden;
}
.pricing::before {
content: '';
position: absolute;
inset: 0;
background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(42,184,212,0.08) 0%, transparent 60%);
pointer-events: none;
}
.pricing .section-title { color: var(--white); }
.pricing .section-sub { color: rgba(255,255,255,0.5); }
.pricing .section-eyebrow { color: var(--aqua); }

.pricing-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
gap: 24px;
margin-top: 60px;
align-items: start;
}

.pricing-card {
background: rgba(255,255,255,0.04);
border: 1px solid rgba(42,184,212,0.2);
border-radius: 6px;
padding: 40px 36px;
position: relative;
transition: transform 0.2s, border-color 0.2s;
}
.pricing-card:hover { transform: translateY(-4px); border-color: var(--aqua); }
.pricing-card.featured { background: rgba(42,184,212,0.08); border-color: var(--aqua); transform: scale(1.03); }
.pricing-card.featured:hover { transform: scale(1.03) translateY(-4px); }

.featured-badge {
position: absolute;
top: -1px; left: 50%;
transform: translateX(-50%);
background: var(--aqua);
color: var(--navy);
font-size: 10px; font-weight: 700;
letter-spacing: 2px; text-transform: uppercase;
padding: 5px 16px;
border-radius: 0 0 6px 6px;
}

.plan-name { font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--aqua); margin-bottom: 16px; }
.plan-price { font-family: 'Bebas Neue', sans-serif; font-size: 64px; color: var(--white); line-height: 1; letter-spacing: 1px; }
.plan-price sup { font-size: 28px; vertical-align: super; }
.plan-price sub { font-size: 16px; color: rgba(255,255,255,0.4); letter-spacing: 0; font-family: 'DM Sans', sans-serif; font-weight: 300; }
.plan-desc { font-size: 13px; color: rgba(255,255,255,0.4); margin: 12px 0 28px; line-height: 1.6; }
.plan-divider { height: 1px; background: rgba(42,184,212,0.2); margin-bottom: 24px; }
.plan-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 36px; }
.plan-features li { font-size: 13px; color: rgba(255,255,255,0.65); display: flex; gap: 10px; align-items: flex-start; line-height: 1.5; }
.plan-features li span.check { color: var(--aqua); font-weight: 700; flex-shrink: 0; }

.btn-plan { display: block; width: 100%; text-align: center; padding: 14px; border-radius: 4px; font-size: 13px; font-weight: 500; letter-spacing: 0.5px; text-decoration: none; transition: all 0.2s; font-family: 'DM Sans', sans-serif; border: none; cursor: pointer; }
.btn-plan-outline { background: transparent; border: 1px solid rgba(42,184,212,0.4); color: var(--aqua); }
.btn-plan-outline:hover { background: var(--aqua); color: var(--navy); }
.btn-plan-fill { background: var(--aqua); color: var(--navy); font-weight: 600; }
.btn-plan-fill:hover { background: var(--aqua-light); }

/* ── HOW IT WORKS ── */
.how { padding: 100px 48px; background: var(--off-white); }
.steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0; margin-top: 60px; position: relative; }
.steps::before { content: ''; position: absolute; top: 36px; left: 10%; right: 10%; height: 1px; background: linear-gradient(90deg, transparent, var(--aqua), var(--aqua), transparent); opacity: 0.3; }
.step { text-align: center; padding: 0 24px; position: relative; }
.step-num { width: 72px; height: 72px; border-radius: 50%; background: var(--white); border: 2px solid var(--aqua); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--aqua); letter-spacing: 1px; position: relative; z-index: 2; }
.step-title { font-family: 'DM Serif Display', serif; font-size: 18px; color: var(--navy); margin-bottom: 10px; }
.step-desc { font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ── DEMO SECTION ── */
.demo {
padding: 100px 48px;
background: var(--navy);
position: relative;
overflow: hidden;
}
.demo::before {
content: '';
position: absolute;
inset: 0;
background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(42,184,212,0.07) 0%, transparent 70%);
pointer-events: none;
}
.demo .section-title { color: var(--white); }
.demo .section-sub { color: rgba(255,255,255,0.5); }
.demo .section-eyebrow { color: var(--aqua); }

.demo-video-wrap {
max-width: 820px;
margin: 0 auto 40px;
border-radius: 12px;
overflow: hidden;
border: 1px solid rgba(42,184,212,0.3);
box-shadow: 0 0 80px rgba(42,184,212,0.12);
}
.demo-video-inner {
position: relative;
width: 100%;
padding-top: 56.25%;
}
.demo-video-inner iframe {
position: absolute;
top: 0; left: 0;
width: 100%; height: 100%;
}
.demo-placeholder {
position: absolute;
top: 0; left: 0; right: 0; bottom: 0;
background: rgba(255,255,255,0.03);
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 14px;
border: 2px dashed rgba(42,184,212,0.25);
border-radius: 12px;
}
.demo-play-btn {
width: 80px;
height: 80px;
border-radius: 50%;
background: var(--aqua);
display: flex;
align-items: center;
justify-content: center;
font-size: 28px;
color: var(--navy);
padding-left: 6px;
box-shadow: 0 0 40px rgba(42,184,212,0.4);
}
.demo-placeholder-text {
font-family: 'DM Serif Display', serif;
font-size: 20px;
color: rgba(255,255,255,0.7);
}
.demo-placeholder-sub {
font-size: 13px;
color: rgba(255,255,255,0.3);
text-align: center;
max-width: 380px;
line-height: 1.6;
}
.demo-cta { text-align: center; }

/* ── TRUST ── */
.trust { padding: 80px 48px; background: var(--white); text-align: center; }
.trust-inner { max-width: 700px; margin: 0 auto; }
.trust-quote { font-family: 'DM Serif Display', serif; font-size: clamp(22px, 3vw, 34px); font-style: italic; color: var(--navy); line-height: 1.4; margin-bottom: 28px; }
.trust-quote em { color: var(--blue); }
.trust-author { font-size: 13px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
.trust-divider { width: 60px; height: 2px; background: linear-gradient(90deg, var(--blue), var(--aqua)); margin: 0 auto 36px; }

/* ── CTA ── */
.cta-section { padding: 100px 48px; background: var(--navy); text-align: center; position: relative; overflow: hidden; }
.cta-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(42,184,212,0.1) 0%, transparent 70%); }
.cta-section .section-title { color: var(--white); margin: 0 auto 16px; max-width: 700px; }
.cta-section .section-sub { color: rgba(255,255,255,0.5); margin: 0 auto 48px; }
.cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; position: relative; }

/* ── FOOTER ── */
footer { background: #070F1A; padding: 48px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; border-top: 1px solid rgba(42,184,212,0.1); }
.footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px; color: var(--white); }
.footer-logo span { color: var(--aqua); }
.footer-copy { font-size: 12px; color: rgba(255,255,255,0.25); letter-spacing: 0.5px; }
.footer-links { display: flex; gap: 28px; }
.footer-links a { font-size: 12px; color: rgba(255,255,255,0.3); text-decoration: none; letter-spacing: 0.5px; transition: color 0.2s; }
.footer-links a:hover { color: var(--aqua); }

/* ── ANIMATIONS ── */
.fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.fade-up.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
nav { padding: 16px 24px; }
.nav-links { display: none; }
.hero { padding: 100px 24px 60px; }
.hero-title { font-size: 72px; }
.problem, .solution, .pricing, .how, .trust, .cta-section { padding: 70px 24px; }
footer { padding: 32px 24px; flex-direction: column; text-align: center; }
.hero-stats { gap: 28px; }
.steps::before { display: none; }
.apps-grid { grid-template-columns: 1fr; }
.pricing-card.featured { transform: scale(1); }
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
<a href="#" class="nav-logo">STREAM<span>FLUX</span></a>
<div class="nav-links">
<a href="#solution">The Tools</a>
<a href="#how">How It Works</a>
