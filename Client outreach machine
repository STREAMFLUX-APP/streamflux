<Field label="Agency / Company Name" value={agencyName} onChange={setAgencyName} placeholder="Rivera Real Estate Group" />
</div>

{error && <div style={{ background: "#1a0a0a", border: "1px solid #3a1a1a", borderRadius: 8, padding: "12px 16px", color: "#f87171", fontSize: 13, marginBottom: 16, fontFamily: "monospace" }}>⚠ {error}</div>}

{loading && <div style={{ background: "#13161b", border: `1px solid ${G.border}`, borderRadius: 10, padding: "18px 22px", marginBottom: 16, textAlign: "center" }}>
<p style={{ color: G.blue, fontSize: 14, margin: 0, fontWeight: 600 }}>{loadingMsg}</p>
<p style={{ color: G.muted, fontSize: 12, margin: "6px 0 0" }}>Takes about 15-20 seconds. Please wait...</p>
</div>}

<button onClick={() => canGenerate && !loading && generate()} disabled={loading || !canGenerate} style={{ ...btnP(!canGenerate || loading), width: "100%", fontSize: 15 }}>
{loading ? "Generating..." : "✦ Generate Full Outreach Package"}
</button>
{!canGenerate && <p style={{ color: G.muted, fontSize: 12, marginTop: 8, textAlign: "center" }}>Fill in client name, client type, contact reason and your name to continue.</p>}
</div>
</div>
);
}
